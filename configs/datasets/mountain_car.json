{
  "env": "mountain_car",
  "dataset_name": "dataset_v1",
  "seed_pool": 2025,
  "seed_test": 2026,
  "num_pool": 2000,
  "num_train": 1600,
  "num_val": 400,
  "num_test": 400,
  "rollout_steps": 30,
