  "controller": {
    "name": "CartPoleController",
    "weights": "../weights/cartpole/controller_cp.pth"
  },
  "decoder": {
    "name": "CartPoleDecoder",
    "weights": "../weights/cartpole/decoder_cp.pth"
  },
  "dynamic": {
    "name": "CartPole"
  },
  "output_dir": "datasets/cartpole/data/dataset_v1"
